<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_student_management" model="ir.module.category">
        <field name="name">Student Management</field>
        <field name="description">Manage access rights for the Student Management module</field>
        <field name="sequence">20</field>
    </record>

    <record id="student_management_privilege" model="res.groups.privilege">
        <field name="name">Student Management</field>
        <field name="category_id" ref="module_category_student_management"/>
    </record>

    <record id="group_student_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="student_management_privilege"/>
    </record>

    <record id="group_student_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="student_management_privilege"/>
        <field name="implied_ids" eval="[(4, ref('group_student_user'))]"/>
    </record>
</odoo>
